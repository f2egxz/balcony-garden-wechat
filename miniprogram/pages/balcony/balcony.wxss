.hero {
  margin-bottom: 48rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  padding: 48rpx !important;
  border: none;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%);
  border-radius: 50%;
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
}

.hero-sub {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

.stats-grid {
  margin-top: 40rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8rpx);
  text-align: center;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.num {
  font-size: 44rpx;
  font-weight: 900;
  color: #ffffff;
}

.label {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.section-group {
  margin-bottom: 56rpx; /* Increased spacing between modules */
}

.suggest-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggest-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx !important;
  background: white;
  border: 1rpx solid var(--line-soft);
}

.suggest-icon {
  font-size: 32rpx;
}

.suggest-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  font-weight: 500;
}

.focus-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.focus-card {
  display: flex;
  align-items: center;
  padding: 0 !important;
  border: none !important;
  overflow: hidden;
}

.focus-accent {
  width: 12rpx;
  height: 120rpx;
  background: var(--warning);
  flex-shrink: 0;
}

.focus-content {
  flex: 1;
  padding: 24rpx 32rpx;
  min-width: 0;
}

.plant-name {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.focus-reason {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.4;
}

.focus-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 4rpx solid var(--text-muted);
  border-right: 4rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-right: 32rpx;
}

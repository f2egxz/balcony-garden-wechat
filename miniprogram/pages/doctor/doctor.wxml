<view class="container">
  <view class="form-card card">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <view class="title">AI 植物医生</view>
      <view class="subtitle">描述症状或上传照片，快速获得专业养护建议。</view>

      <view class="field">
        <view class="label-row">
          <view class="label-icon">🪴</view>
          <text class="label">关联植物（可选）</text>
        </view>
        <picker mode="selector" range="{{plants}}" range-key="plant_name" value="{{selectedPlantIndex}}" bindchange="onPlantChange">
          <view class="picker {{selectedPlantIndex >= 0 ? 'filled' : ''}}">
            {{selectedPlantIndex >= 0 ? plants[selectedPlantIndex].plant_name : '请选择我的植物'}}
            <view class="picker-arrow"></view>
          </view>
        </picker>
      </view>

      <view class="field">
        <view class="label-row">
          <view class="label-icon">🔍</view>
          <text class="label">症状描述</text>
        </view>
        <textarea class="textarea" placeholder-class="placeholder" placeholder="例如：叶子变黄、边缘发焦、出现白色粉末..." bindinput="onQuestionInput" />
      </view>

      <view class="field">
        <view class="label-row">
          <view class="label-icon">📸</view>
          <text class="label">图片上传（可选）</text>
        </view>
        <view class="upload-area">
          <button class="upload-btn" bindtap="chooseImage">
            <view class="upload-btn-content">
              <view class="plus-icon">+</view>
              <text>上传照片</text>
            </view>
          </button>
          <view wx:if="{{localImagePath}}" class="preview-container">
            <image class="preview" src="{{localImagePath}}" mode="aspectFill"></image>
            <view class="remove-btn" bindtap="removeImage">×</view>
          </view>
        </view>
      </view>

      <button class="primary-btn submit-btn {{submitting ? 'loading' : ''}}" bindtap="submitDiagnosis">
        {{submitting ? '诊断中...' : '开始 AI 智能诊断'}}
      </button>
    </view>
  </view>

  <view wx:if="{{diagnosis}}" class="result-section">
    <view class="section-title">诊断报告</view>
    <view class="card result-card">
      <view class="result-accent"></view>
      <view class="result-content">
        <view class="block">
          <view class="block-title">
            <text class="block-icon">🧐</text> 可能原因
          </view>
          <view class="line-group">
            <view wx:for="{{diagnosis.possible_causes}}" wx:key="*this" class="line">{{item}}</view>
          </view>
        </view>

        <view class="block">
          <view class="block-title">
            <text class="block-icon">💡</text> 建议操作
          </view>
          <view class="line-group">
            <view wx:for="{{diagnosis.suggestions}}" wx:key="*this" class="line highlight">{{item}}</view>
          </view>
        </view>

        <view class="block" wx:if="{{diagnosis.cautions && diagnosis.cautions.length}}">
          <view class="block-title warning">
            <text class="block-icon">⚠️</text> 注意事项
          </view>
          <view class="line-group">
            <view wx:for="{{diagnosis.cautions}}" wx:key="*this" class="line">{{item}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="history-section">
    <view class="section-title">最近诊断记录</view>
    <view wx:if="{{history.length}}" class="history-list">
      <view wx:for="{{history}}" wx:key="diagnosis_id" class="history-card card">
        <view class="history-main">
          <view class="history-q">{{item.question || '图片诊断记录'}}</view>
          <view class="history-time">{{item.time_text}}</view>
        </view>
        <view class="history-arrow"></view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <view class="empty-icon">📂</view>
      <view class="empty-text">暂无历史诊断记录</view>
    </view>
  </view>
</view>

.form-card {
  margin-bottom: 40rpx;
  background: white;
  padding: 40rpx !important;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle at 70% 30%, rgba(6, 182, 212, 0.08) 0%, transparent 70%);
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #164e63;
}

.subtitle {
  font-size: 26rpx;
  color: #64748b;
  margin: 12rpx 0 40rpx;
  line-height: 1.5;
}

.field {
  margin-bottom: 32rpx;
}

.label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 28rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
}

.picker,
.textarea {
  background: #f8fafc;
  border-radius: var(--radius-md);
  border: 2rpx solid #f1f5f9;
  transition: all 0.2s ease;
}

.picker {
  height: 96rpx;
  padding: 0 32rpx;
  color: #94a3b8;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filled {
  color: #1e293b;
  font-weight: 600;
}

.picker-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 4rpx solid #cbd5e1;
  border-bottom: 4rpx solid #cbd5e1;
  transform: rotate(45deg);
  margin-top: -6rpx;
}

.textarea {
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.placeholder {
  color: #cbd5e1;
}

.upload-area {
  display: flex;
  gap: 24rpx;
}

.upload-btn {
  width: 200rpx !important;
  height: 200rpx !important;
  background: #f8fafc !important;
  border: 4rpx dashed #e2e8f0 !important;
  border-radius: var(--radius-md) !important;
  margin: 0 !important;
  padding: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.plus-icon {
  font-size: 48rpx;
  color: #94a3b8;
  font-weight: 300;
}

.upload-btn text {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

.preview-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ef4444;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  z-index: 5;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.submit-btn {
  margin-top: 48rpx;
  background: linear-gradient(135deg, #0891b2, #06b6d4) !important;
  box-shadow: 0 12rpx 24rpx rgba(6, 182, 212, 0.2) !important;
}

.result-card {
  padding: 0 !important;
  border: none !important;
  display: flex;
}

.result-accent {
  width: 12rpx;
  background: #06b6d4;
  flex-shrink: 0;
}

.result-content {
  flex: 1;
  padding: 40rpx;
}

.block {
  margin-bottom: 32rpx;
}

.block:last-child {
  margin-bottom: 0;
}

.block-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #164e63;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.block-title.warning {
  color: #b91c1c;
}

.line-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.line {
  color: #475569;
  font-size: 26rpx;
  line-height: 1.6;
}

.line.highlight {
  color: #0e7490;
  font-weight: 600;
  background: #ecfeff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.history-section {
  padding: 24rpx 0;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx !important;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-q {
  font-size: 28rpx;
  font-weight: 700;
  color: #334155;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.history-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 4rpx solid #cbd5e1;
  border-right: 4rpx solid #cbd5e1;
  transform: rotate(45deg);
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}

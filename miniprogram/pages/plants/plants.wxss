.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  background: var(--bg-card);
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.header-sub {
  margin-top: 4rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.add-btn {
  height: 72rpx !important;
  line-height: 72rpx !important;
  padding: 0 32rpx !important;
  font-size: 24rpx !important;
}

.plus {
  font-size: 32rpx;
  margin-right: 6rpx;
  margin-top: -4rpx;
}

.plant-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.plant-card {
  padding: 32rpx !important;
}

.plant-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.plant-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.plant-status {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.plant-status.normal {
  background: var(--brand-soft);
  color: var(--brand-deep);
}

.plant-info {
  display: flex;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label {
  font-size: 20rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.plant-reminders {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.reminder-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-card-soft);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--line-soft);
}

.tag-icon {
  font-size: 24rpx;
}

.plant-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--brand-deep);
  font-weight: 700;
}

.footer-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 4rpx solid var(--brand-deep);
  border-right: 4rpx solid var(--brand-deep);
  transform: rotate(45deg);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.empty-desc {
  margin: 16rpx 0 40rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.empty-btn {
  width: fit-content !important;
}

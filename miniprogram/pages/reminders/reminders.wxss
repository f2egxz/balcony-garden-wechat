.header-card {
  margin-bottom: 32rpx;
  background: var(--bg-card);
  padding: 40rpx !important;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.header-sub {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.subscribe-btn {
  border: none;
  background: var(--brand-soft);
  color: var(--brand-deep);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 22rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.subscribe-btn:active {
  background: var(--brand-light);
}

.subscribe-btn::after {
  border: none;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 32rpx;
}

.stat-card {
  border-radius: var(--radius-md);
  padding: 24rpx 20rpx;
  text-align: center;
  border: 1rpx solid var(--line-soft);
}

.stat-card.overdue {
  background: #fffafa;
  border-color: #fee2e2;
}

.stat-card.today {
  background: var(--brand-soft);
  border-color: var(--brand-light);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 900;
}

.stat-card.overdue .stat-value { color: var(--danger); }
.stat-card.today .stat-value { color: var(--brand-deep); }

.stat-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.reminder-card {
  display: flex;
  padding: 0 !important;
  border: none !important;
  overflow: hidden;
}

.reminder-accent {
  width: 12rpx;
  flex-shrink: 0;
}

.reminder-accent.p-high { background: var(--danger); }
.reminder-accent.p-medium { background: var(--warning); }
.reminder-accent.p-low { background: var(--brand); }

.reminder-main {
  flex: 1;
  padding: 32rpx;
  min-width: 0;
}

.reminder-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.plant-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--brand-deep);
  background: var(--brand-soft);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.priority-badge {
  font-size: 18rpx;
  font-weight: 800;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  color: white;
}

.priority-badge.p-high { background: var(--danger); }
.priority-badge.p-medium { background: var(--warning); }
.priority-badge.p-low { background: var(--brand); }

.reminder-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.4;
}

.reminder-meta {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.separator {
  opacity: 0.3;
}

.done-btn {
  margin-top: 32rpx;
  width: 100% !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  font-size: 26rpx !important;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.empty-desc {
  margin-top: 16rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

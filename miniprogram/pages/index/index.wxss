.hero {
  margin-bottom: 40rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  padding: 40rpx;
  border: none;
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-decoration {
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%);
  z-index: 1;
  border-radius: 50%;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-tag {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  backdrop-filter: blur(4rpx);
}

.hero-date {
  font-size: 24rpx;
  opacity: 0.9;
  font-weight: 500;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 44rpx;
  line-height: 1.4;
  font-weight: 800;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: 0.85;
  line-height: 1.5;
}

.hero-btn {
  margin-top: 32rpx;
  background: #ffffff !important;
  color: var(--brand-deep) !important;
  width: fit-content !important;
  margin-left: 0 !important;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1) !important;
}

.task-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-count {
  background: var(--brand-soft);
  color: var(--brand-deep);
  border-radius: 999rpx;
  padding: 4rpx 20rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 0 !important;
  border: none !important;
}

.task-accent {
  width: 12rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.status-high { background: var(--warning); }
.status-medium { background: #60a5fa; }
.status-low { background: var(--brand); }

.task-main {
  flex: 1;
  padding: 24rpx 32rpx;
  min-width: 0;
}

.task-plant {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.task-tip {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.task-right {
  padding: 24rpx 32rpx;
  text-align: right;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100rpx;
}

.task-level {
  font-size: 20rpx;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  color: #fff;
  font-weight: 700;
  align-self: flex-end;
}

.level-high { background: var(--warning); }
.level-medium { background: #60a5fa; }
.level-low { background: var(--brand); }

.task-arrow {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 24rpx;
  color: var(--text-muted);
}

.arrow-icon {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid var(--text-muted);
  border-right: 3rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.hint {
  background: var(--bg-card-soft);
  display: flex;
  gap: 24rpx;
  border: 1rpx solid var(--line-soft);
}

.hint-icon {
  font-size: 40rpx;
}

.hint-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hint-text {
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.hint-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hint-actions button {
  flex: 1;
  height: 72rpx !important;
  font-size: 24rpx !important;
  padding: 0 !important;
}

.hero-card {
  margin-bottom: 40rpx;
  background: white;
  padding: 40rpx !important;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle at 70% 30%, rgba(16, 185, 129, 0.08) 0%, transparent 70%);
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.plant-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.meta-row {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.meta-badge {
  background: var(--brand-soft);
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
}

.meta-badge .label {
  font-size: 18rpx;
  color: var(--brand-deep);
  text-transform: uppercase;
  font-weight: 700;
  opacity: 0.7;
}

.meta-badge .value {
  font-size: 26rpx;
  color: var(--brand-deep);
  font-weight: 800;
}

.detail-list {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.item-icon {
  font-size: 28rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.quick-btn {
  background: white !important;
  border: 1rpx solid var(--line-soft) !important;
  padding: 20rpx 0 !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: var(--radius-md) !important;
  box-shadow: var(--shadow-sm) !important;
}

.quick-btn:active {
  background: var(--bg-card-soft) !important;
  transform: translateY(2rpx);
}

.btn-icon {
  font-size: 40rpx;
}

.quick-btn text {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.quick-btn.doctor {
  background: var(--brand-soft) !important;
  border-color: var(--brand-light) !important;
}

.quick-btn.doctor text {
  color: var(--brand-deep);
}

.timeline-container {
  padding: 40rpx !important;
}

.timeline-item {
  display: flex;
  gap: 24rpx;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 24rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--brand);
  border-radius: 50%;
  margin-top: 10rpx;
  z-index: 2;
  box-shadow: 0 0 0 6rpx var(--brand-light);
}

.line {
  flex: 1;
  width: 2rpx;
  background: var(--line-soft);
  margin-top: 4rpx;
}

.timeline-item:last-child .line {
  display: none;
}

.timeline-content {
  flex: 1;
  padding-bottom: 32rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.record-time {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.record-note {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  background: var(--bg-card-soft);
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
}

.timeline-empty {
  padding: 60rpx 40rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

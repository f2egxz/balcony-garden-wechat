view, scroll-view, swiper, picker, button {
  box-sizing: border-box;
}

page {
  --bg-page: #f0f4f1;
  --bg-card: #ffffff;
  --bg-card-soft: #f8faf9;
  --line-soft: #e2ede4;
  --text-primary: #1a1c1a;
  --text-secondary: #4a554d;
  --text-muted: #8a9a8e;
  --brand: #10b981;
  --brand-deep: #059669;
  --brand-light: #d1fae5;
  --brand-soft: #ecfdf5;
  --ai: #06b6d4;
  --warning: #f59e0b;
  --danger: #ef4444;
  
  --radius-xl: 32rpx;
  --radius-lg: 24rpx;
  --radius-md: 16rpx;
  --radius-sm: 8rpx;
  
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  --shadow-sm: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 12rpx rgba(16, 185, 129, 0.08);
  --shadow-lg: 0 12rpx 32rpx rgba(16, 185, 129, 0.12);

  background: 
    radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%),
    radial-gradient(at 100% 0%, rgba(6, 182, 212, 0.05) 0px, transparent 50%),
    #f0f4f1;
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  min-height: 100%;
}

.container {
  padding: var(--space-lg) var(--space-md) calc(var(--space-xl) + 44rpx);
  box-sizing: border-box;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: "";
  width: 8rpx;
  height: 32rpx;
  background: var(--brand);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-sm);
}

.muted {
  color: var(--text-muted);
  font-size: 24rpx;
}

.empty {
  padding: 80rpx 40rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.6);
  color: var(--text-secondary);
  text-align: center;
  border: 4rpx dashed var(--line-soft);
  backdrop-filter: blur(10px);
}

.primary-btn {
  background: linear-gradient(135deg, var(--brand), var(--brand-deep));
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 0 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.25);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 10rpx rgba(16, 185, 129, 0.2);
  opacity: 0.9;
}

.ghost-btn {
  background: var(--brand-soft);
  color: var(--brand-deep);
  border: 1rpx solid var(--brand-light);
  border-radius: var(--radius-md);
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.ghost-btn:active {
  background: var(--brand-light);
}

.primary-btn::after, .ghost-btn::after {
  border: none;
}
